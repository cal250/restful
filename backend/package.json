    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.16.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/pdfkit": "^0.13.8",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "prisma": "6.19.3",
